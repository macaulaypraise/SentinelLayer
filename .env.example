# .env.example — copy to .env, fill in values

# Nokia Network-as-Code
NAC_CLIENT_ID=your_nac_client_id
NAC_CLIENT_SECRET=your_nac_client_secret
NAC_BASE_URL=https://network-as-code.nokia.com/api
NAC_TOKEN_URL=https://network-as-code.nokia.com/oauth2/token

# PostgreSQL (local dev uses docker-compose values below)
DATABASE_URL=postgresql+asyncpg://sentinel:dev@localhost:5432/sentinellayer

# Redis (local dev)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Kafka (local dev)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_FRAUD_SIGNALS_TOPIC=sentinel.fraud.signals
KAFKA_MODE2_TOPIC=sentinel.mode2.triggers

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=sentinellayer
SENTRY_DSN=

# Firebase (Mode 2 alerts)
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_PROJECT_ID=
FRAUD_DESK_FCM_TOKEN=
TELECOM_TEAM_FCM_TOKEN=

# Google Maps (Mode 3)
GOOGLE_MAPS_API_KEY=

# Application
RISK_THRESHOLD_MODE2=45
RISK_THRESHOLD_HOLD=70
SIM_SWAP_WINDOW_HOURS=72
CONSENT_CACHE_TTL_SECONDS=300
APP_ENV=development
PORT=8000

# Copy and fill in your values
# Edit .env with your Nokia NaC sandbox credentials
